# Aegis SOC server environment variables (copy -> .env or export in your shell).

# --- Database ---
# SQLite (default) or PostgreSQL:
#   postgresql+psycopg://postgres:<password>@127.0.0.1:5432/aegis
AEGIS_DATABASE_URL=sqlite:///./data/aegis.db
# In production set to 0 and use Alembic (alembic upgrade head):
AEGIS_AUTO_CREATE=1

# --- API security ---
# Comma-separated API keys. EMPTY = auth disabled (local/demo only).
AEGIS_API_KEYS=
# Allowed CORS origins (UI):
AEGIS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Requests-per-minute limit (0 = disabled):
AEGIS_RATE_LIMIT_PER_MIN=0
# Require an API key on read endpoints too (1 = on; default 0 keeps the demo dashboard open):
AEGIS_REQUIRE_AUTH_READS=0

# --- Retention ---
# Days to keep data; scripts/prune.py removes older closed/resolved alerts (0 = keep all):
AEGIS_RETENTION_DAYS=0

# --- Notifications (Phase C) ---
# Webhook URL (Slack-compatible JSON) posted on each new high-severity alert (empty = off):
AEGIS_WEBHOOK_URL=

# --- Login hardening (Milestone 1) ---
# HS256 secret for issued JWTs (empty = random per-process; set a stable value in production):
AEGIS_JWT_SECRET=
# Account lockout policy for /api/auth/login:
AEGIS_AUTH_MAX_FAILS=5
AEGIS_AUTH_LOCK_SECONDS=300

# --- Server-side request inspection / WAF (Milestone 2) ---
# 1 = scan inbound request URLs for SQLi/XSS/traversal/cmdi signatures and raise waf_detection:
AEGIS_WAF_DETECT=0

# --- Automated response / IP auto-block (Milestone 6) ---
# 1 = auto-block the source IP of alerts whose rule is in AEGIS_AUTO_BLOCK_RULES (BlocklistMiddleware
# then returns 403). Manual blocks via POST/DELETE /api/blocklist/{ip} work regardless of this flag.
AEGIS_AUTO_BLOCK=0
AEGIS_AUTO_BLOCK_RULES=web-bruteforce,bruteforce-success,canary-triggered,network-flood,waf-signature

# --- For the PostgreSQL init script ---
# PGPASSWORD=<password>
