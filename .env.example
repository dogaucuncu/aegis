# Aegis SOC sunucusu ortam değişkenleri (kopyala -> .env veya kabukta export et).

# --- Veritabanı ---
# SQLite (varsayılan) veya PostgreSQL:
#   postgresql+psycopg://postgres:<sifre>@127.0.0.1:5432/aegis
AEGIS_DATABASE_URL=sqlite:///./data/aegis.db
# Üretimde 0 yapıp Alembic kullanın (alembic upgrade head):
AEGIS_AUTO_CREATE=1

# --- API güvenliği ---
# Virgüllü API anahtarları. BOŞ = auth kapalı (yalnızca yerel/demo).
AEGIS_API_KEYS=
# İzinli CORS origin'leri (UI):
AEGIS_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Dakika başına istek limiti (0 = kapalı):
AEGIS_RATE_LIMIT_PER_MIN=0

# --- PostgreSQL init scripti için ---
# PGPASSWORD=<sifre>
